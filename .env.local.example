# Verdé — local environment example.
# Copy to `.env.local`. The default below runs the full Tier-1 loop with the
# local adapters (in-memory data, mock anonymous auth, recorded AI fixtures) and
# makes ZERO calls to Google Cloud (ADR-002, FR-11).

# Selects the adapter set. One of: local | gcp. Defaults to `local` if unset.
APP_ENV=local

# ---------------------------------------------------------------------------
# GCP configuration (only needed when APP_ENV=gcp). Leave commented for local.
# Never commit real secrets — these are resolved via Secret Manager in prod.
# ---------------------------------------------------------------------------
# GCP_PROJECT_ID=your-gcp-project-id
# FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase web client config (anonymous auth + linkWithCredential). Public,
# but kept here for local-vs-prod parity; sourced from Secret Manager in prod.
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# Gemini API access (server-side only; resolved via SecretsPort, never logged).
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
