# dependencies
/node_modules
/.pnp
.pnp.*

# next.js
/.next/
/out/
next-env.d.ts

# production / standalone build
/build

# testing
/coverage
/playwright-report
/test-results
/.playwright

# env files (keep .env.local.example, ignore real ones)
.env
.env.local
.env*.local
!.env.local.example

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# os / editor
.DS_Store
*.pem
.vscode/*
!.vscode/extensions.json
.idea

# typescript / tooling caches
*.tsbuildinfo
.eslintcache

# firebase emulator artifacts
*-debug.log
.firebase/

# personal / not-for-the-repo
/LINKEDIN-POST.md

# submission / dev-internal artifacts (not part of the deliverable)
# (inline comments are not allowed in .gitignore — keep each pattern on its own line)
# design-review/: 15 MB of reference screenshots — excluded to keep the repo under the 10 MB limit
/design-review/
# .claude/: local Claude Code tooling
/.claude/
# .se/: intern-pipeline working state (the durable ADRs are preserved under docs/adr/)
/.se/
