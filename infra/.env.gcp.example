# Verdé — GCP (Cloud Run) environment template.
#
# DEPLOY ARTIFACT ONLY. No real secrets live here. Copy the structure into your
# `gcloud run deploy` flags / `infra/cloudrun.yaml`. Secret VALUES come from
# Secret Manager at runtime (`--set-secrets`), NEVER from a committed file.
#
# This mirrors `.env.local.example` but for APP_ENV=gcp. The local file is what
# you copy to `.env.local` for `npm run dev`; THIS file documents the cloud-mode
# surface. Do not put this content in `.env.local` and run it locally — it would
# attempt real GCP calls.

# ---------------------------------------------------------------------------
# Adapter selection
# ---------------------------------------------------------------------------
# Selects the GCP adapter set (Firestore / Firebase Auth / Secret Manager /
# Gemini). MUST be `gcp` for any Cloud Run deploy. `src/server/env.ts` fails
# fast if APP_ENV=gcp and neither GCP_PROJECT_ID nor FIREBASE_PROJECT_ID is set.
APP_ENV=gcp

# Standard production flag. Set by the Dockerfile runner stage already; declared
# here for parity.
NODE_ENV=production

# ---------------------------------------------------------------------------
# Project identity (plain runtime env vars — NOT secrets)
# ---------------------------------------------------------------------------
# GCP project that owns Firestore / Artifact Registry / Secret Manager. Used by
# the Firestore + Firebase Admin adapters (src/server/adapters/gcp/app.ts) to
# resolve the project. Either GCP_PROJECT_ID or FIREBASE_PROJECT_ID must be set.
GCP_PROJECT_ID=your-gcp-project-id

# Firebase/Identity Platform project for anonymous auth + linkWithCredential.
# In single-project setups this equals GCP_PROJECT_ID.
FIREBASE_PROJECT_ID=your-gcp-project-id

# ---------------------------------------------------------------------------
# Secrets (resolved from Secret Manager at runtime via --set-secrets)
# ---------------------------------------------------------------------------
# Gemini API key. NOT a literal here. Injected by Cloud Run from Secret Manager:
#   --set-secrets=GEMINI_API_KEY=gemini-api-key:latest
# The SecretManagerSecretsPort (src/server/adapters/gcp/secrets.ts) reads it from
# the process env that Cloud Run populates from the mounted secret. The value is
# never logged and is reachable only through the SecretsPort.
# GEMINI_API_KEY=__from_secret_manager__

# ---------------------------------------------------------------------------
# Optional tuning
# ---------------------------------------------------------------------------
# Override the Gemini model the AI adapter uses. Optional; the adapter has a
# default. Plain env var, not a secret.
# GEMINI_MODEL=gemini-2.5-flash

# ---------------------------------------------------------------------------
# Firebase web client config (PUBLIC, browser-side anonymous auth).
# ---------------------------------------------------------------------------
# These NEXT_PUBLIC_* values are baked at BUILD time and are public by design
# (they identify the Firebase project to the browser SDK; they are not secrets).
# Required for the client to run signInAnonymously() / linkWithCredential() once
# the F4 hardening lands (verify-and-echo). Set them as build args / build-time
# env if you build the image per-environment.
# NEXT_PUBLIC_FIREBASE_API_KEY=your-public-web-api-key
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-gcp-project-id.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-gcp-project-id
# NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-web-app-id
